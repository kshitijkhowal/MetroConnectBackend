{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "MetroConnect Backend",
    "description": "API collection for MetroConnectBackend (Supabase auth + profiles).\n\n## Setup\n1. Import this collection and `MetroConnectBackend.postman_environment.json`.\n2. Select the **MetroConnect Local** environment.\n3. Paste a Google ID token into `googleIdToken` (from the mobile app / Google Sign-In).\n4. Run **Auth → Sign in with Google** — tests save `accessToken`, `refreshToken`, and `userId`.\n\nBase URL defaults to `http://localhost:3000`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "googleIdToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Liveness probe. No auth required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Community",
      "item": [
        {
          "name": "List contributors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/community/contributors",
              "host": ["{{baseUrl}}"],
              "path": ["api", "community", "contributors"]
            },
            "description": "Public list of community contributors. No auth required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign in with Google",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.session?.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', data.session.accessToken);",
                  "    pm.environment.set('accessToken', data.session.accessToken);",
                  "  }",
                  "  if (data.session?.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', data.session.refreshToken);",
                  "    pm.environment.set('refreshToken', data.session.refreshToken);",
                  "  }",
                  "  if (data.user?.id) {",
                  "    pm.collectionVariables.set('userId', data.user.id);",
                  "    pm.environment.set('userId', data.user.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{googleIdToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/google",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "google"]
            },
            "description": "Exchange a Google ID token for a Supabase session and upsert the profile.\n\nSet `googleIdToken` in the environment (or collection variables) first."
          },
          "response": []
        },
        {
          "name": "Refresh session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.session?.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', data.session.accessToken);",
                  "    pm.environment.set('accessToken', data.session.accessToken);",
                  "  }",
                  "  if (data.session?.refreshToken) {",
                  "    pm.collectionVariables.set('refreshToken', data.session.refreshToken);",
                  "    pm.environment.set('refreshToken', data.session.refreshToken);",
                  "  }",
                  "  if (data.user?.id) {",
                  "    pm.collectionVariables.set('userId', data.user.id);",
                  "    pm.environment.set('userId', data.user.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "refresh"]
            },
            "description": "Rotate the session using a refresh token. Updates stored tokens on success."
          },
          "response": []
        },
        {
          "name": "Get me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Return the current user and profile. Requires Bearer access token."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Invalidate the current session (best-effort). Expects 204."
          },
          "response": []
        }
      ]
    },
